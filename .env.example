# Copy to .env and fill in. The pipeline loads this automatically via python-dotenv.

# --- API keys ---
GEMINI_API_KEY=your-google-ai-studio-key
OPENAI_API_KEY=your-openai-key

# --- Model IDs (defaults match the proposal doc; override if your deployment differs) ---
GEMINI_MODEL=gemini-3.5-flash
OPENAI_MODEL=gpt-5.4-mini

# --- Generation settings ---
# Stage 1 annotator temperature (0 = most deterministic verbatim rewriting)
ANNOTATOR_TEMPERATURE=0
# Stage 2 auditor temperature
AUDITOR_TEMPERATURE=0

# --- Paths ---
OUTPUT_DIR=output
