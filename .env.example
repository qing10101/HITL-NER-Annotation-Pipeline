# Copy to .env and fill in. The pipeline loads this automatically via python-dotenv.

# --- API keys (only the providers you actually use are required) ---
GEMINI_API_KEY=your-google-ai-studio-key
OPENAI_API_KEY=your-openai-key

# --- Model selection, per role: "<provider>:<model>" ---
# Known providers: openai, gemini. Swap freely (or override with CLI
# --annotator-model / --auditor-model). Current setup: Gemini annotates, GPT judges.
ANNOTATOR_MODEL=gemini:gemini-3.5-flash
AUDITOR_MODEL=openai:gpt-5.5

# --- Generation settings ---
# Annotator temperature (0 = most deterministic verbatim rewriting)
ANNOTATOR_TEMPERATURE=0
# Auditor/judge temperature
AUDITOR_TEMPERATURE=1

# --- Paths ---
OUTPUT_DIR=output
